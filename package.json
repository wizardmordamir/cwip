      "bun": {
        "types": "./dist/ops/testing/index.d.ts",
        "import": "./dist/ops/testing/index.js"
      },
      "default": {
        "types": "./dist/ops/testing/index.d.ts",
        "import": "./dist/ops/testing/_noBun.js"
      }
    }
  },
  "bin": {
    "cwip": "./dist/bin/cwip.js",
    "taskq": "./dist/bin/taskq.js"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "apptest": "bun run scripts/appTest",
    "build": "bun run clean && tsc -p tsconfig.build.json && bun run scripts/fixEsmExtensions.ts && bun run scripts/copyStaticAssets.ts",
    "check": "bun x biome check ./src && bun run typecheck",
    "fix": "bun x biome check --write --unsafe ./src",
    "clean": "rm -rf dist",
    "done": "bun run check && bun run test && bun run build",
    "dryrunpublish": "bun publish --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "test": "bun test --bail --preload ./src",
    "prepublishOnly": "bun run done"
  },
  "license": "ISC",
