{
  // Publish build: emit per-file ESM + declarations from src, excluding all
  // test/spec sources. Standalone (no project references) so `tsc -p` won't
  // pull in tsconfig.spec.json and ship test code to npm.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "declaration": true,
    // Source isn't published (files: ["dist"]), so source/declaration maps would
    // point at files that don't ship — omit them to keep the package lean. Add
    // "src" to package.json `files` and flip these on if you want go-to-source DX.
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false
  },
  "references": [],
  "include": ["src"],
  "exclude": ["dist", "node_modules", "*.ignore*", "src/**/*.spec.ts", "src/**/*.spec.tsx", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
